#MD System
timestep 1.0

velocity all create 300 56575
velocity argon set 0.0 0.0 0.0 #10eV sind 0.069 A/fs

fix 1 all nve

compute pe_nitrogen nitrogen pe/atom
compute ke_nitrogen nitrogen ke/atom
compute pe_droplet droplet pe/atom
compute ke_droplet droplet ke/atom
compute pe_argon argon pe/atom
compute pot_drop droplet reduce sum c_pe_droplet
compute pot_nitro nitrogen reduce sum c_pe_nitrogen
compute kin_drop droplet reduce sum c_ke_droplet

thermo_style custom step etotal ke density temp press vol c_pot_drop c_pot_nitro c_kin_drop
thermo 100

dump 1 all custom 500 collision_velset.lammpstrj id mol type x y z ix iy iz vx vy vz c_pe_droplet c_ke_droplet c_pe_argon c_pe_nitrogen c_ke_nitrogen

dump 2 all dcd 500 collision_velset.dcd

run   10000
