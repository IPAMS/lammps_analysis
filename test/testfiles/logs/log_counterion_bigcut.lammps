#MD System

timestep 1.0

velocity all create 300 56575

fix 1 all npt temp 300.0 300.0 100.0 iso 0.00001 0.00001 100.0 drag 1.0

compute pe_all all pe/atom
compute ke_all all ke/atom
compute pot_drop droplet reduce sum c_pe_all
compute pot_nitro nitrogen reduce sum c_pe_all
compute kin_drop droplet reduce sum c_ke_all
compute kin_nitro nitrogen reduce sum c_ke_all

thermo_style custom step etotal pe ke density temp press vol c_pot_drop c_pot_nitro c_kin_drop c_kin_nitro

thermo 100


dump 1 all custom 500 h2o_n2_ch3oh_counterion_bigcut.lammpstrj id mol type x y z ix iy iz vx vy vz c_pe_all c_ke_all


